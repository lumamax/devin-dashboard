# Local storage backend. `local` is the supported default.
# Use `omniroute` only when migrating old private OmniRoute-backed data.
DEVIN_DASHBOARD_STORE=local

# Cross-platform dashboard data directory.
# Defaults: macOS/Linux ~/.devin-dashboard, Windows %APPDATA%\devin-dashboard.
# DEVIN_DASHBOARD_HOME=

# Optional exact local store file. Useful for tests or portable dev bundles.
# DEVIN_DASHBOARD_STORE_PATH=

# Legacy migration mode only. Ignored unless DEVIN_DASHBOARD_STORE=omniroute.
# OMNIROUTE_URL=http://localhost:20128
# OMNIROUTE_TOKEN=
# OMNIROUTE_DB_PATH=

# Optional. When the SSR page is rendered, the dashboard fetches its own
# /api/accounts route. If you change the port or host this needs to follow.
# DEVIN_DASHBOARD_INTERNAL_URL=http://127.0.0.1:29128

# Where to store per-account Chrome profiles.
# Each connection id gets its own subdirectory. Defaults to the local dashboard home/profiles.
# DEVIN_PROFILE_ROOT=

# Optional override for the Chrome binary path. Auto-detected per-OS by default.
# CHROME_BINARY_PATH=

# Optional override for the "source" Chrome profile to extract cookies from.
# Defaults to your OS's default Chrome user data dir.
# CHROME_SOURCE_PROFILE=


# GitHub App broker MVP. Long-term shared-repo control plane.
# App id from GitHub App settings.
# GITHUB_APP_ID=

# Preferred for local setup: paste the private key PEM and keep literal \n escapes.
# GITHUB_APP_PRIVATE_KEY=

# Optional alternative if you want to store the private key base64-encoded instead.
# GITHUB_APP_PRIVATE_KEY_BASE64=

# Optional but recommended: webhook secret for validating GitHub deliveries.
# GITHUB_APP_WEBHOOK_SECRET=

# Optional hints used by the local broker endpoints.
# GITHUB_APP_OWNER=lumamax
# GITHUB_APP_INSTALLATION_ID=
